# EditorConfig — convención única de encoding y formato para todo el repo.
# Evita mojibake y diffs ruidosos por fin de línea / espacios.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
# En Markdown, dos espacios al final pueden ser saltos de línea intencionales.
trim_trailing_whitespace = false
indent_size = 2

[*.{js,mjs,json,css,html}]
indent_size = 2

[Makefile]
indent_style = tab
